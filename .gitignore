# --- Transient MCP / WhatsApp artifacts (not part of the project) ---
*.lock
mcp-logs.txt
wa-logs.txt
*-logs.txt

# --- OS / editor ---
.DS_Store
Thumbs.db
desktop.ini

# --- Python ---
__pycache__/
*.pyc

# --- R ---
.Rproj.user/
.Rhistory
.RData
.Ruserdata

# --- Node / PWA build (future app/) ---
node_modules/
dist/
build/
.vite/
*.log

# --- Large generated geodata / tiles (regenerated from inputs) ---
*.pmtiles
*.mbtiles

# --- Fotos: originales crudos NO se versionan (pesados). Solo las versiones
#     web optimizadas en app/public/img/ entran al repo (las genera el script
#     data_prep/10_process_photos.py). Ver docs/MEDIA_SYSTEM.md.
inmersive_app/inputs/photos/incoming/**
inmersive_app/inputs/photos/_originals/**
!inmersive_app/inputs/photos/incoming/README.md
!inmersive_app/inputs/photos/incoming/.gitkeep

# --- Mosaicos satelitales (copia de tiles Esri; regenerables, ~13MB; Dropbox respalda) ---
inmersive_app/inputs/maps/satellite/*.jpg
inmersive_app/inputs/maps/satellite/*.jgw
inmersive_app/inputs/maps/satellite/*.prj

# --- SIC info/: contiene material PRIVADO (escrituras, contabilidad, media, WhatsApp).
#     NADA de info/ entra al repo salvo el catálogo generado y los censos json/txt.
#     Ver docs/SISTEMA_INFORMACION.md. (Antes solo se ignoraban pdf/office → fuga de
#     .rar/.mp4/.jpg privados; ahora blanket + negaciones explícitas.) ---
info/**
!info/INDEX.md
!info/catalog.json
!info/censos_inventarios/
!info/censos_inventarios/*.json
!info/censos_inventarios/*.txt

# --- SIC: fotos de campo del juego (originales; Dropbox respalda; se reingieren) ---
inmersive_app/inputs/photos/field/_incoming/*.json
inmersive_app/inputs/photos/field/_procesados/**
inmersive_app/inputs/photos/field/**/*.jpg
inmersive_app/inputs/photos/field/**/*.jpeg
inmersive_app/inputs/photos/field/**/*.png
!inmersive_app/inputs/photos/field/.gitkeep

# --- SIC: archivo de fotos de los papás (fotos Y VIDEOS crudos; Dropbox respalda;
#     clasificado local). Solo el catálogo generado + LÉEME entran al repo. ---
fotos/**
!fotos/catalog_fotos.json
!fotos/LÉEME.txt

# --- Secrets ---
.env
.env.*
!.env.example
# --- SQLite WAL/SHM transitorios de los GeoPackage (no versionar) ---
*.gpkg-wal
*.gpkg-shm

# --- Archivo crudo de la reserva (41GB; Dropbox respalda; NO al repo) ---
Reserva natural cantares/
