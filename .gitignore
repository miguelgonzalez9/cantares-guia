# --- Transient MCP / WhatsApp artifacts (not part of the project) ---
*.lock
mcp-logs.txt
wa-logs.txt
*-logs.txt

# --- OS / editor ---
.DS_Store
Thumbs.db
desktop.ini

# --- R ---
.Rproj.user/
.Rhistory
.RData
.Ruserdata

# --- Node / PWA build (future app/) ---
node_modules/
dist/
build/
.vite/
*.log

# --- Large generated geodata / tiles (regenerated from inputs) ---
*.pmtiles
*.mbtiles

# --- Fotos: originales crudos NO se versionan (pesados). Solo las versiones
#     web optimizadas en app/public/img/ entran al repo (las genera el script
#     data_prep/10_process_photos.py). Ver docs/MEDIA_SYSTEM.md.
inmersive_app/inputs/photos/incoming/**
inmersive_app/inputs/photos/_originals/**
!inmersive_app/inputs/photos/incoming/README.md
!inmersive_app/inputs/photos/incoming/.gitkeep

# --- Mosaicos satelitales (copia de tiles Esri; regenerables, ~13MB; Dropbox respalda) ---
inmersive_app/inputs/maps/satellite/*.jpg
inmersive_app/inputs/maps/satellite/*.jgw
inmersive_app/inputs/maps/satellite/*.prj

# --- Secrets ---
.env
.env.*
!.env.example
# --- SQLite WAL/SHM transitorios de los GeoPackage (no versionar) ---
*.gpkg-wal
*.gpkg-shm
