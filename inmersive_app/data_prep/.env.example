# Plantilla de variables locales para el Sistema de Información Cantares.
#
# CÓMO USARLA:
#   1. Copia este archivo y renómbralo a  .env  (en la misma carpeta data_prep/).
#   2. Pega tu clave de Pl@ntNet después del = (sin comillas, sin espacios).
#   3. Guarda. El archivo .env NO se sube a git (está en .gitignore); vive solo en tu PC.
#
# La clave gratis se obtiene en https://my.plantnet.org  (Cuenta → API → 500/día).

PLANTNET_API_KEY=

# eBird (AVES): clave para enriquecer y listar aves de la zona (17_ebird_birds.py).
# NO identifica fotos (eso lo hace BioCLIP en modo cerrado); da la taxonomía oficial
# (familia, orden, nombres común es/en) y la lista de especies reportadas cerca.
#   Clave gratis, NO expira:  https://ebird.org/api/keygen
EBIRD_API_KEY=

# (Opcional, fase futura — déjala vacía)
GOOGLE_VISION_KEY=
